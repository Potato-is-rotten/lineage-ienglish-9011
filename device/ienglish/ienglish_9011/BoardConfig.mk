# BoardConfig.mk for iEnglish 9011

# 架构
TARGET_ARCH := arm
TARGET_ARCH_VARIANT := armv8-a
TARGET_CPU_ABI := armeabi-v7a
TARGET_CPU_ABI2 := armeabi
TARGET_CPU_VARIANT := cortex-a53
TARGET_CPU_VARIANT_RUNTIME := cortex-a53

# 64位Binder
TARGET_USES_64_BIT_BINDER := true

# 平台
TARGET_BOARD_PLATFORM := mt6739
TARGET_BOARD_PLATFORM_GPU := mali-450

# 分区大小 (根据原厂调整)
BOARD_SYSTEMIMAGE_PARTITION_SIZE := 3221225472
BOARD_VENDORIMAGE_PARTITION_SIZE := 536870912
BOARD_USERDATAIMAGE_PARTITION_SIZE := 10737418240
BOARD_CACHEIMAGE_PARTITION_SIZE := 268435456
BOARD_RECOVERYIMAGE_PARTITION_SIZE := 33554432
BOARD_BOOTIMAGE_PARTITION_SIZE := 33554432

# 分区类型
TARGET_USERIMAGES_USE_EXT4 := true
BOARD_VENDORIMAGE_FILE_SYSTEM_TYPE := ext4
BOARD_CACHEIMAGE_FILE_SYSTEM_TYPE := ext4

# 内核
TARGET_KERNEL_SOURCE := kernel/ienglish/ienglish_9011
TARGET_KERNEL_CONFIG := ienglish_9011_defconfig
BOARD_KERNEL_BASE := 0x40078000
BOARD_KERNEL_PAGESIZE := 2048
BOARD_KERNEL_OFFSET := 0x00008000
BOARD_RAMDISK_OFFSET := 0x14f88000
BOARD_TAGS_OFFSET := 0x13f88000
BOARD_KERNEL_CMDLINE := bootopt=64S3,32S1,32S1 androidboot.selinux=permissive

# Recovery
TARGET_RECOVERY_FSTAB := device/ienglish/ienglish_9011/recovery.fstab

# SELinux
BOARD_SEPOLICY_DIRS += device/ienglish/ienglish_9011/sepolicy

# 屏幕密度
TARGET_SCREEN_DENSITY := 213

# VNDK - Android 10
BOARD_VNDK_VERSION := current

# Treble
BOARD_PROPERTY_OVERRIDES_SPLIT_ENABLED := true
TARGET_FULL_TREBLE := true

# 安全补丁级别
VENDOR_SECURITY_PATCH := 2018-12-05

# Android 10 特定配置
TARGET_USES_PREBUILT_VENDOR_IMAGE := true
